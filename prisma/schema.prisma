generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Deal {
  id                     String              @id
  fingerprint            String              @unique
  buyerNameCn            String
  buyerNameEn            String?
  buyerTicker            String?
  sellerNames            String[]
  targetNameCn           String
  targetNameEn           String?
  targetCountry          String?
  targetAssetLocation    String?
  targetIndustry         String?
  targetBusiness         String?
  dealDirection          String
  transactionType        String
  stakeBefore            Float?
  stakeChange            Float?
  stakeAfter             Float?
  obtainsControl         Boolean?
  considerationAmount    Float?
  considerationCurrency  String?
  considerationText      String?
  paymentMethods         String[]
  currentStage           String
  currentStatus          String
  articleTitle           String
  articleBody            String
  detailedSummary        String?
  transactionFacts       String?
  transactionStructure   String?
  targetProfile          Json?
  targetFinancials       Json?
  considerationBreakdown Json?
  pricingBasis           String?
  approvalsAndConditions Json?
  keyDates               Json?
  fieldEvidence          Json?
  lastVerifiedAt         DateTime?
  isManualSupplement     Boolean             @default(false)
  informationGaps        String[]
  visibleTags            String[]
  importanceScore        Int
  importanceBreakdown    Json
  validationStatus       String
  manualPriority         Int?
  firstAnnouncementDate  DateTime
  latestAnnouncementDate DateTime
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  events                 DealEvent[]
  sources                DealSource[]
  reviewItems            ReviewItem[]
  moderationRequests     ModerationRequest[]
  manualSubmissions      ManualSubmission[]
  statusChangeLogs       StatusChangeLog[]
}

model DealEvent {
  id                String       @id
  dealId            String
  announcementDate  DateTime
  announcementType  String
  transactionStage  String
  title             String
  body              String
  sourceData        Json
  evidence          Json
  sourceFingerprint String       @unique
  createdAt         DateTime     @default(now())
  deal              Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sourceLinks       DealSource[]
}

model DealSource {
  id                String     @id
  dealId            String
  eventId           String?
  title             String
  url               String
  publisher         String?
  sourceType        String     @default("wind_record")
  isPrimary         Boolean    @default(false)
  linkStatus        String     @default("valid")
  lastVerifiedAt    DateTime?
  windRecordId      String?
  publishedAt       DateTime?
  sourceFingerprint String     @unique
  createdAt         DateTime   @default(now())
  deal              Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  event             DealEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model WeeklyIssue {
  id                  String    @id
  startDate           DateTime
  endDate             DateTime
  title               String
  summary             String
  dealIds             String[]
  candidateCount      Int
  includedCount       Int
  excludedCount       Int
  reviewRequiredCount Int
  publishedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model IngestionRun {
  id                  String              @id
  issueId             String?
  runStartedAt        DateTime
  runCompletedAt      DateTime?
  fromDate            DateTime
  toDate              DateTime
  candidateCount      Int
  includedCount       Int
  excludedCount       Int
  reviewRequiredCount Int
  status              String
  payload             Json
  excludedItems       Json
  errors              Json
  createdAt           DateTime            @default(now())
  excludedCandidates  ExcludedCandidate[]
  reviewItems         ReviewItem[]
}

model ExcludedCandidate {
  id                 String              @id
  runId              String
  candidateName      String
  buyerName          String?
  buyerTicker        String?
  targetName         String?
  announcementDate   DateTime?
  announcementTitle  String
  source             String?
  sourceUrl          String?
  sourceTitle        String?
  linkStatus         String              @default("not_publicly_available")
  informationGaps    String[]            @default([])
  windRecordId       String?
  exclusionReason    String
  mayReconsider      Boolean             @default(false)
  status             String              @default("excluded")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  run                IngestionRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  moderationRequests ModerationRequest[]
  statusChangeLogs   StatusChangeLog[]
}

model ReviewItem {
  id                 String              @id
  runId              String?
  dealId             String?
  reason             String
  payload            Json
  status             String              @default("open")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  run                IngestionRun?       @relation(fields: [runId], references: [id], onDelete: SetNull)
  deal               Deal?               @relation(fields: [dealId], references: [id], onDelete: SetNull)
  moderationRequests ModerationRequest[]
  statusChangeLogs   StatusChangeLog[]
}

model ModerationRequest {
  id                  String             @id
  targetType          String
  targetId            String
  requestedAction     String
  reason              String
  status              String             @default("pending")
  createdAt           DateTime           @default(now())
  reviewedAt          DateTime?
  resolutionNote      String?
  requestHash         String             @unique
  deal                Deal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId              String?
  reviewItem          ReviewItem?        @relation(fields: [reviewItemId], references: [id], onDelete: SetNull)
  reviewItemId        String?
  excludedCandidate   ExcludedCandidate? @relation(fields: [excludedCandidateId], references: [id], onDelete: SetNull)
  excludedCandidateId String?
}

model ManualSubmission {
  id                String    @id
  title             String
  sourceUrl         String?
  status            String    @default("submitted")
  createdAt         DateTime  @default(now())
  reviewedAt        DateTime?
  reviewNote        String?
  linkedDealId      String?
  linkedDealEventId String?
  submissionHash    String    @unique
  deal              Deal?     @relation(fields: [linkedDealId], references: [id], onDelete: SetNull)
}

model StatusChangeLog {
  id                  String             @id
  targetType          String
  targetId            String
  previousStatus      String
  nextStatus          String
  reason              String
  moderationRequestId String?
  createdAt           DateTime           @default(now())
  dealId              String?
  reviewItemId        String?
  excludedCandidateId String?
  deal                Deal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  reviewItem          ReviewItem?        @relation(fields: [reviewItemId], references: [id], onDelete: SetNull)
  excludedCandidate   ExcludedCandidate? @relation(fields: [excludedCandidateId], references: [id], onDelete: SetNull)
}

model TeaserOpportunity {
  id                 String             @id @default(uuid())
  projectCode        String?
  title              String
  companyName        String?
  companyNameEn      String?
  country            String?
  region             String?
  industry           String?
  subsector          String?
  businessSummary    String?
  industryOverview   String?
  companyOverview    String?
  productOverview    String?
  revenue            Float?
  ebitda             Float?
  netProfit          Float?
  ebitdaMargin       Float?
  revenueGrowth      Float?
  ebitdaGrowth       Float?
  netProfitGrowth    Float?
  currency           String?
  revenueUsd         Float?
  ebitdaUsd          Float?
  netProfitUsd       Float?
  fxRateToUsd        Float?
  fxRateDate         DateTime?
  financialYear      String?
  transactionType    String?
  stakeOffered       Float?
  advisor            String?
  advisorContactName String?
  advisorContactEmail String?
  advisorContactPhone String?
  operatingLocations String[]           @default([])
  companyHighlights  String[]           @default([])
  processStage       String             @default("new")
  reviewStatus       String             @default("review_required")
  confidence         Float?
  tags               String[]           @default([])
  latestDocumentAt   DateTime            @default(now())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  documents          TeaserDocument[]
  reviewItems        TeaserReviewItem[]

  @@index([industry])
  @@index([country])
  @@index([reviewStatus])
  @@index([latestDocumentAt])
}

model TeaserDocument {
  id                 String             @id @default(uuid())
  opportunityId      String?
  fingerprint        String             @unique
  fileName           String
  mimeType           String
  fileSize           Int
  storageProvider    String
  storageKey         String
  storageUrl         String?
  sourceType         String
  sourceLabel        String?
  originalUrl        String?
  status             String             @default("queued")
  versionLabel       String?
  documentType       String?
  documentDate       DateTime?
  language           String?
  pageCount          Int?
  uploadedBy         String             @default("Changyuan Ju")
  uploadedAt         DateTime           @default(now())
  processedAt        DateTime?
  errorMessage       String?
  extractedData      Json?
  fieldEvidence      Json?
  confidence         Float?
  opportunity        TeaserOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  reviewItems        TeaserReviewItem[]

  @@index([status])
  @@index([sourceType])
  @@index([uploadedAt])
}

model TeaserReviewItem {
  id                 String             @id @default(uuid())
  documentId         String
  opportunityId      String?
  type               String
  fieldName          String?
  message            String
  status             String             @default("open")
  payload            Json?
  createdAt          DateTime           @default(now())
  resolvedAt         DateTime?
  resolvedBy         String?
  document           TeaserDocument     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  opportunity        TeaserOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model TeaserSourceConnection {
  id                 String   @id @default(uuid())
  type               String
  name               String
  status             String   @default("not_configured")
  localPath          String?
  lastSyncAt         DateTime?
  itemCount          Int      @default(0)
  config             Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([type, name])
}
